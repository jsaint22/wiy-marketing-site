# wiy-marketing-site — Environment Variables Example
# Copy to .env.local for local dev. Real values live in Vercel project env vars
# (vercel env pull --environment=production/preview to sync locally).
# Never commit real values — placeholders only in this file.

# ----------------------------------------------------------------------------
# Resend — transactional email (lead-magnet PDF delivery)
# ----------------------------------------------------------------------------
RESEND_API_KEY=YOUR_RESEND_API_KEY

# ----------------------------------------------------------------------------
# GHL — contact upsert + tag application (lead-magnet flow + AUM math)
# ----------------------------------------------------------------------------
GHL_API_TOKEN=YOUR_GHL_PIT_TOKEN
GHL_LOCATION_ID=YOUR_GHL_LOCATION_ID

# ----------------------------------------------------------------------------
# Lead-magnet → ops-portal Inngest webhook (Spec 1)
# ----------------------------------------------------------------------------
# HMAC-signed POST emitted from src/app/api/lead-magnet/route.ts to the
# ops-portal receiver at /api/webhooks/lead-magnet. Powers Spec 1
# (lead-magnet Inngest nurture).
#
# CONTRACT (must match ops-portal receiver byte-for-byte):
#   - Header:   x-wiy-signature: sha256=<hex>
#   - Algo:     HMAC-SHA256 over the raw request body
#   - Secret:   INTAKE_WEBHOOK_SECRET (THIS VALUE) — MUST BE BYTE-IDENTICAL
#               to ops-portal's INTAKE_WEBHOOK_SECRET env var. Reuses the
#               existing intake webhook secret per Josh 2026-05-20 PM10
#               (accepting per-surface secret rotation tradeoff for
#               operational simplicity; previously a dedicated
#               LEAD_MAGNET_WEBHOOK_SECRET).
#
# Generate (one-time): openssl rand -hex 32
# Provision via Vercel CLI on BOTH projects (production + preview):
#   printf "%s" "$VALUE" | vercel env add INTAKE_WEBHOOK_SECRET production
#   printf "%s" "$VALUE" | vercel env add INTAKE_WEBHOOK_SECRET preview
# Repeat for ops-portal Vercel project with the SAME value.
INTAKE_WEBHOOK_SECRET=YOUR_INTAKE_WEBHOOK_SECRET

# Ops-portal receiver endpoint. Per environment:
#   - production: https://ops.wealthinyourself.com/api/webhooks/lead-magnet
#   - preview:    https://<preview-deployment>.vercel.app/api/webhooks/lead-magnet
#   - dev (local): http://localhost:3001/api/webhooks/lead-magnet
#     (ops-portal is started with PORT=3001 to avoid colliding with
#     wiy-marketing-site on default port 3000)
LEAD_MAGNET_WEBHOOK_URL=https://ops.wealthinyourself.com/api/webhooks/lead-magnet
